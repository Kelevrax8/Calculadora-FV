{
    "name": "ipte/calculadora-fv",
    "description": "Calculadora de sistemas fotovoltaicos interconectados",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "phpoffice/phpspreadsheet": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.5"
    },
    "config": {
        "optimize-autoloader": true
    }
}
